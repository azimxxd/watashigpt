hotkeys:
  intercept: ctrl+alt+x
  undo: ctrl+alt+z
  silent_toggle: ctrl+alt+s
confidence_threshold: 0.7
interaction_mode: both
silent_mode: true
ui:
  mode: silent
  show_success_notifications: false
  show_error_popups: false
  show_result_popups: false
  log_level: info
  notify_on_image_save: true
  log_path: ~/.actionflow.log
  error_dedupe_window_seconds: 8
platform:
  clipboard_backend: auto
  window_backend: auto
app:
  launch_at_startup: false
  debug_console: false
image_generation:
  provider: pollinations
  base_url: https://gen.pollinations.ai/image
  model: flux
  width: 1024
  height: 1024
  timeout: 60
commands:
  b64:
    description: Base64 encode text
    keywords:
    - encode
    - base64
    prefixes:
    - 'B64:'
    - 'BASE64:'
  bullets:
    description: Convert text to bullet list (LLM)
    keywords:
    - bullet
    - bullets
    - list
    llm_prompt: 'Convert the following text into a clean markdown bullet-point list.
      Return ONLY the bullet points, nothing else:


      {text}'
    llm_required: true
    prefixes:
    - 'BULLETS:'
    - 'LIST:'
  calc:
    description: Safe math expression evaluator
    keywords:
    - calculate
    - math
    - eval
    prefixes:
    - 'CALC:'
    - 'MATH:'
  clip:
    description: Internal named text store (save/load/list/delete/clear)
    keywords:
    - clip save
    - clip load
    - clip list
    prefixes:
    - 'CLIP:'
  command:
    description: Run an allowlisted system command and show real output
    keywords:
    - run
    - execute
    - shell
    - terminal
    prefixes:
    - 'CMD:'
    - 'RUN:'
    - 'EXEC:'
  count:
    description: Realistic word/char/line stats with reading time
    keywords:
    - count
    - stats
    - words
    prefixes:
    - 'COUNT:'
    - 'STATS:'
  date:
    description: Natural language date → ISO format
    keywords:
    - date
    - when is
    prefixes:
    - 'DATE:'
  decode:
    description: Base64 decode text
    keywords:
    - decode
    - unbase64
    prefixes:
    - 'DECODE:'
    - 'DB64:'
  define:
    description: Safe dictionary lookup with ranked definitions
    keywords:
    - define
    - definition
    - meaning of
    prefixes:
    - 'DEFINE:'
  image:
    description: Generate image from text (Pollinations.ai)
    keywords:
    - image
    - picture
    - generate image
    - draw
    prefixes:
    - 'IMG:'
    - 'IMAGE:'
  docstring:
    description: Generate code docstring (LLM)
    keywords:
    - docstring
    - document
    llm_prompt: 'Generate a docstring/documentation comment for the following code.
      Detect the language and use the appropriate format (Python docstring, JSDoc,
      etc.). Return ONLY the docstring/comment block:


      {text}'
    llm_required: true
    prefixes:
    - 'DOCSTRING:'
    - 'DOC:'
  eli5:
    description: Explain like I am 5 (LLM)
    keywords:
    - eli5
    - simple
    llm_prompt: 'Explain the following as if to a 5-year-old. Use simple words, analogies,
      and short sentences. Return ONLY the explanation:


      {text}'
    llm_required: true
    prefixes:
    - 'ELI5:'
  email:
    description: Generate a clean single-language email draft (LLM)
    keywords:
    - email
    - draft email
    llm_prompt: 'Turn the following rough notes into a professional email with a subject
      line and body. Format as "Subject: ...\n\n..." Return ONLY the email:


      {text}'
    llm_required: true
    prefixes:
    - 'EMAIL:'
  escape:
    description: Escape text predictably for JSON/Python/regex/HTML/shell/SQL
    keywords:
    - escape
    prefixes:
    - 'ESCAPE:'
    - 'ESC:'
  explain:
    description: Explain text or code clearly instead of paraphrasing it (LLM)
    keywords:
    - explain
    - what does
    - how does
    - meaning
    llm_prompt: 'Explain the following in simple terms (2-3 sentences max):


      {text}'
    llm_required: true
    prefixes:
    - 'EXP:'
    - 'EXPLAIN:'
  fill:
    description: Fill {{placeholders}} with explicit values or context (LLM)
    keywords:
    - fill
    - template
    llm_prompt: 'The following text contains {{placeholder}} markers. Infer appropriate
      values from context and fill them in. Return ONLY the completed text with all
      placeholders replaced:


      {text}'
    llm_required: true
    prefixes:
    - 'FILL:'
  fmt:
    description: Auto-format JSON/XML
    keywords:
    - format
    - prettify
    - indent
    prefixes:
    - 'FMT:'
    - 'FORMAT:'
  gitcommit:
    description: Generate git commit message (LLM)
    keywords:
    - commit message
    - git commit
    llm_prompt: 'Generate a conventional commit message for the following changes/diff.
      Use the format: type: short description. Return ONLY the commit message:


      {text}'
    llm_required: true
    prefixes:
    - 'GITCOMMIT:'
    - 'COMMIT:'
  haiku:
    description: Turn the idea into a short haiku-style poem (LLM)
    keywords:
    - haiku
    - poem
    llm_prompt: 'Write a haiku (5-7-5 syllable poem) inspired by the theme of the
      following text. Return ONLY the haiku:


      {text}'
    llm_required: true
    prefixes:
    - 'HAIKU:'
  hash:
    description: SHA256 hex digest
    keywords:
    - hash
    - sha256
    - digest
    prefixes:
    - 'HASH:'
    - 'SHA:'
  meeting:
    description: Structure meeting notes (LLM)
    keywords:
    - meeting
    - meeting notes
    llm_prompt: 'Structure the following rough meeting notes into formatted sections:
      ## Summary, ## Decisions, ## Action Items, ## Follow-ups. Return ONLY the structured
      notes:


      {text}'
    llm_required: true
    prefixes:
    - 'MEETING:'
    - 'NOTES:'
  mock:
    description: Spongebob alternating caps
    keywords:
    - mock
    - spongebob
    - sarcasm
    prefixes:
    - 'MOCK:'
    - 'SPONGE:'
  password:
    description: Generate strong random password
    keywords:
    - password
    - generate password
    password_config:
      length: 20
    prefixes:
    - 'PASSWORD:'
    - 'PASSWD:'
    - 'PW:'
  pop:
    description: Pop the latest item from the internal text stack
    keywords:
    - pop
    - restore
    prefixes:
    - 'POP:'
  redact:
    description: Mask PII (emails, phones, cards, IPs)
    keywords:
    - redact
    - mask
    - pii
    prefixes:
    - 'REDACT:'
    - 'PII:'
  regex:
    description: Generate regex from description (LLM)
    keywords:
    - regex
    - pattern
    llm_prompt: 'Generate a regular expression pattern for the following description.
      Return ONLY the regex pattern on line 1, then a brief explanation on line 2:


      {text}'
    llm_required: true
    prefixes:
    - 'REGEX:'
  repeat:
    description: Re-run last command on current selection
    keywords:
    - repeat
    - again
    prefixes:
    - 'REPEAT:'
    - 'AGAIN:'
  review:
    description: Quick code review (LLM)
    keywords:
    - review
    - code review
    llm_prompt: 'Review the following code. Identify bugs, style issues, and potential
      improvements. Return a concise bullet list of findings:


      {text}'
    llm_required: true
    prefixes:
    - 'REVIEW:'
    - 'CR:'
  rewrite:
    description: Rewrite text professionally (LLM)
    keywords:
    - rewrite
    - improve
    - better
    - fix writing
    strength: strong
    llm_prompt: 'You are a text rewriting engine, not a chatbot.
      Rewrite the provided text in the SAME LANGUAGE as the source text.
      Preserve the original meaning, but improve clarity, fluency, structure, tone, and wording.
      If the source text is short, rough, simplistic, or poorly phrased, expand it slightly into a more natural, polished, and well-formed sentence while keeping the same core meaning.
      A minimal punctuation-only fix is not enough if the source is clearly underwritten.
      The output should be noticeably better written than the input.
      Do not translate unless explicitly requested.
      Do not add commentary, explanations, greetings, disclaimers, or meta-text.
      Return ONLY the rewritten text:


      {text}'
    llm_required: true
    prefixes:
    - 'RW:'
    - 'REWRITE:'
  roast:
    description: Light roast of selected text (LLM)
    keywords:
    - roast
    llm_prompt: 'Write a short, witty, light-hearted roast of the following text or
      code. Be funny but not mean. Return ONLY the roast:


      {text}'
    llm_required: true
    prefixes:
    - 'ROAST:'
  sanitize:
    description: Strip HTML/markdown/ANSI formatting
    keywords:
    - sanitize
    - strip
    - clean
    prefixes:
    - 'SANITIZE:'
    - 'STRIP:'
    - 'CLEAN:'
  stack:
    description: Push text into an internal LIFO stack
    keywords:
    - stack
    - push
    prefixes:
    - 'STACK:'
    - 'PUSH:'
  summarize:
    description: Summarize text (LLM)
    keywords:
    - summarize
    - tldr
    - shorten
    - brief
    llm_prompt: 'Summarize the following text in 1-2 concise sentences:


      {text}'
    llm_required: true
    prefixes:
    - 'SUM:'
    - 'TLDR:'
  test:
    description: Test the capture-process-replace pipeline
    keywords:
    - test
    - ping
    - check
    prefixes:
    - 'TEST:'
    - 'PING:'
  title:
    description: Generate a short headline (LLM)
    keywords:
    - title
    - headline
    llm_prompt: 'Generate a short, punchy title/headline for the following text. Return
      ONLY the title, nothing else:


      {text}'
    llm_required: true
    prefixes:
    - 'TITLE:'
    - 'HEADLINE:'
  todo:
    description: Extract action items as checklist (LLM)
    keywords:
    - todo
    - action items
    - tasks
    llm_prompt: 'Extract all actionable items from the following text. Return as a
      numbered checklist. Return ONLY the checklist:


      {text}'
    llm_required: true
    prefixes:
    - 'TODO:'
    - 'ACTIONS:'
  tone:
    description: Rewrite in a specific tone (LLM)
    keywords:
    - tone
    llm_required: true
    prefixes:
    - 'TONE:'
  trans:
    description: Translate text to a target language (LLM)
    keywords:
    - translate to
    llm_prompt: 'Translate the following text to {lang}. Return ONLY the translated
      text, nothing else:


      {text}'
    llm_required: true
    prefixes:
    - 'TRANS:'
  translate:
    description: Translate text to a target language (LLM alias for TR:<LANG>:)
    keywords:
    - translate
    - translate to
    - convert language
    llm_prompt: 'Translate the payload into the requested target language code and
      return ONLY the translation. No commentary, no greetings, no explanations:


      {text}'
    llm_required: true
    prefixes:
    - 'TR:'
  tweet:
    description: Shorten text to 280 chars (LLM)
    keywords:
    - tweet
    - shorten
    llm_prompt: 'Rewrite the following text to fit within 280 characters (a tweet).
      Preserve the core message. Return ONLY the shortened text:


      {text}'
    llm_required: true
    prefixes:
    - 'TWEET:'
  wiki:
    description: Wikipedia summary with better ambiguity handling
    keywords:
    - wiki
    - wikipedia
    - lookup
    prefixes:
    - 'WIKI:'
hotkeys:
  exit: ctrl+c
  intercept: ctrl+alt+x
  undo: ctrl+alt+z
  silent_toggle: ctrl+alt+s
context_priorities:
  terminal:
  - command
  - explain
  - regex
  - docstring
  - review
  browser:
  - summarize
  - translate
  - rewrite
  - bullets
  - title
  ide:
  - docstring
  - review
  - explain
  - gitcommit
  - regex
  - fmt
  chat:
  - rewrite
  - tone
  - translate
  - tweet
  docs:
  - rewrite
  - summarize
  - bullets
  - title
  - meeting
personal_commands: {}
  # Example:
  # standup:
  #   trigger: "STANDUP:"
  #   description: "Format text as standup update"
  #   examples:
  #     - input: "worked on auth, fixing bug 123"
  #       output: |
  #         **Yesterday:** Worked on authentication module
  #         **Today:** Fixing bug #123
  #         **Blockers:** None
command_security:
  allowed_commands: [ls, cat, grep, find, git, echo, date, python, node, curl, wc, head, tail, sort, uniq, diff, file, stat, whoami, hostname, uname, env, printenv, which, type]
llm:
  mode: auto   # auto | mock ; mock must be explicit
  api_key: ''  # Optional. Prefer ACTIONFLOW_API_KEY env var or ~/.actionflow_secrets.yaml
  fallback:
    api_key: ''
    model: ''
    provider: ''
  model: llama-3.3-70b-versatile
  provider: groq
